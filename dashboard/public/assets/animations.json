{
  "meta": {
    "description": "Pikachu Volleyball animation frame data for multiplayer game engine",
    "spritesheet": "/assets/images/sprite_sheet.png",
    "spritesheetData": "/assets/images/sprite_sheet.json",
    "coordinateSystem": "Original game uses 432x304 virtual resolution"
  },
  "pikachu": {
    "frameSize": { "w": 64, "h": 64 },
    "states": {
      "idle": {
        "frames": ["pikachu/pikachu_0_0.png"],
        "frameDuration": 0,
        "loop": false,
        "description": "Standing still, neutral position"
      },
      "walk": {
        "frames": [
          "pikachu/pikachu_0_0.png",
          "pikachu/pikachu_0_1.png",
          "pikachu/pikachu_0_2.png",
          "pikachu/pikachu_0_3.png",
          "pikachu/pikachu_0_4.png"
        ],
        "frameDuration": 3,
        "loop": true,
        "description": "Walking left/right (flip horizontally for direction)"
      },
      "jump_prepare": {
        "frames": ["pikachu/pikachu_1_0.png"],
        "frameDuration": 2,
        "loop": false,
        "description": "Crouching before jump"
      },
      "jump_up": {
        "frames": [
          "pikachu/pikachu_1_0.png",
          "pikachu/pikachu_1_1.png",
          "pikachu/pikachu_1_2.png",
          "pikachu/pikachu_1_3.png",
          "pikachu/pikachu_1_4.png"
        ],
        "frameDuration": 2,
        "loop": false,
        "description": "Jumping upward"
      },
      "jump_down": {
        "frames": [
          "pikachu/pikachu_2_0.png",
          "pikachu/pikachu_2_1.png",
          "pikachu/pikachu_2_2.png",
          "pikachu/pikachu_2_3.png",
          "pikachu/pikachu_2_4.png"
        ],
        "frameDuration": 2,
        "loop": false,
        "description": "Falling downward"
      },
      "dive_prepare": {
        "frames": [
          "pikachu/pikachu_3_0.png",
          "pikachu/pikachu_3_1.png"
        ],
        "frameDuration": 2,
        "loop": false,
        "description": "Preparing to dive (power move)"
      },
      "spike": {
        "frames": ["pikachu/pikachu_4_0.png"],
        "frameDuration": 4,
        "loop": false,
        "description": "Spiking the ball (single powerful frame)"
      },
      "diving": {
        "frames": [
          "pikachu/pikachu_5_0.png",
          "pikachu/pikachu_5_1.png",
          "pikachu/pikachu_5_2.png",
          "pikachu/pikachu_5_3.png",
          "pikachu/pikachu_5_4.png"
        ],
        "frameDuration": 2,
        "loop": false,
        "description": "Diving animation"
      },
      "lying_down": {
        "frames": [
          "pikachu/pikachu_6_0.png",
          "pikachu/pikachu_6_1.png",
          "pikachu/pikachu_6_2.png",
          "pikachu/pikachu_6_3.png",
          "pikachu/pikachu_6_4.png"
        ],
        "frameDuration": 3,
        "loop": false,
        "description": "Lying on ground after losing point"
      }
    },
    "stateTransitions": {
      "idle": ["walk", "jump_prepare"],
      "walk": ["idle", "jump_prepare"],
      "jump_prepare": ["jump_up"],
      "jump_up": ["jump_down", "spike", "dive_prepare"],
      "jump_down": ["idle", "lying_down"],
      "dive_prepare": ["diving"],
      "diving": ["lying_down"],
      "spike": ["jump_down"],
      "lying_down": ["idle"]
    }
  },
  "ball": {
    "frameSize": { "w": 40, "h": 40 },
    "states": {
      "rotate": {
        "frames": [
          "ball/ball_0.png",
          "ball/ball_1.png",
          "ball/ball_2.png",
          "ball/ball_3.png",
          "ball/ball_4.png"
        ],
        "frameDuration": 2,
        "loop": true,
        "description": "Normal ball rotation during flight"
      },
      "hyper": {
        "frames": ["ball/ball_hyper.png"],
        "frameDuration": 0,
        "loop": false,
        "description": "Hyper ball (power spike visual)"
      },
      "punch": {
        "frames": ["ball/ball_punch.png"],
        "frameDuration": 0,
        "loop": false,
        "description": "Ball after being punched"
      },
      "trail": {
        "frames": ["ball/ball_trail.png"],
        "frameDuration": 0,
        "loop": false,
        "description": "Speed trail effect behind fast-moving ball"
      }
    }
  },
  "background": {
    "layers": {
      "sky": {
        "frame": "objects/sky_blue.png",
        "tileMode": "repeat",
        "size": { "w": 16, "h": 16 },
        "description": "Tiled sky background"
      },
      "mountain": {
        "frame": "objects/mountain.png",
        "size": { "w": 432, "h": 64 },
        "position": { "x": 0, "y": 160 },
        "description": "Mountain range backdrop"
      },
      "cloud": {
        "frame": "objects/cloud.png",
        "size": { "w": 48, "h": 24 },
        "description": "Cloud (animated position)"
      },
      "wave": {
        "frame": "objects/wave.png",
        "tileMode": "repeat-x",
        "size": { "w": 16, "h": 32 },
        "description": "Wave pattern at sea level"
      }
    },
    "ground": {
      "line": {
        "frame": "objects/ground_line.png",
        "leftmost": "objects/ground_line_leftmost.png",
        "rightmost": "objects/ground_line_rightmost.png",
        "size": { "w": 16, "h": 16 }
      },
      "fill": {
        "red": "objects/ground_red.png",
        "yellow": "objects/ground_yellow.png",
        "size": { "w": 16, "h": 16 }
      }
    }
  },
  "net": {
    "pillar": {
      "frame": "objects/net_pillar.png",
      "top": "objects/net_pillar_top.png",
      "size": { "w": 8, "h": 8 },
      "position": { "x": 213, "y": 160 },
      "height": 56,
      "description": "Net pillar at center of court"
    }
  },
  "shadow": {
    "frame": "objects/shadow.png",
    "size": { "w": 32, "h": 8 },
    "description": "Shadow under pikachu and ball"
  },
  "ui": {
    "scoreDigits": {
      "frames": [
        "number/number_0.png", "number/number_1.png",
        "number/number_2.png", "number/number_3.png",
        "number/number_4.png", "number/number_5.png",
        "number/number_6.png", "number/number_7.png",
        "number/number_8.png", "number/number_9.png"
      ],
      "size": { "w": 32, "h": 32 }
    },
    "messages": {
      "ready": "messages/common/ready.png",
      "gameEnd": "messages/common/game_end.png",
      "gameStart": {
        "ja": "messages/ja/game_start.png",
        "ko": "messages/ko/game_start.png"
      },
      "fight": {
        "ja": "messages/ja/fight.png",
        "ko": "messages/ko/fight.png"
      },
      "title": {
        "ja": "messages/ja/pikachu_volleyball.png",
        "ko": "messages/ko/pikachu_volleyball.png"
      },
      "pokemon": {
        "ja": "messages/ja/pokemon.png",
        "ko": "messages/ko/pokemon.png"
      },
      "withComputer": {
        "ja": "messages/ja/with_computer.png",
        "ko": "messages/ko/with_computer.png"
      },
      "withFriend": {
        "ja": "messages/ja/with_friend.png",
        "ko": "messages/ko/with_friend.png"
      },
      "mark": {
        "ja": "messages/ja/mark.png",
        "ko": "messages/ko/mark.png"
      }
    },
    "sittingPikachu": {
      "frame": "sitting_pikachu.png",
      "size": { "w": 104, "h": 104 },
      "description": "Sitting pikachu for title/menu screen"
    },
    "sachisoft": {
      "frame": "messages/common/sachisoft.png",
      "size": { "w": 360, "h": 20 },
      "description": "SACHI SOFT credits text"
    }
  },
  "gameConstants": {
    "court": {
      "width": 432,
      "height": 304,
      "groundY": 244,
      "netX": 216,
      "netTopY": 160,
      "ceilingY": 0
    },
    "physics": {
      "gravity": 1,
      "playerSpeed": 6,
      "jumpVelocity": -16,
      "ballGravity": 0.5,
      "ballMaxSpeed": 20,
      "ballRadius": 20,
      "playerWidth": 64,
      "playerHeight": 64
    },
    "scoring": {
      "maxScore": 15,
      "winBy": 1
    }
  },
  "sounds": {
    "ballbounce": { "wav": "/assets/sounds/ballbounce.wav", "m4a": "/assets/sounds/ballbounce.m4a" },
    "pi": { "wav": "/assets/sounds/pi.wav", "m4a": "/assets/sounds/pi.m4a" },
    "pika": { "wav": "/assets/sounds/pika.wav", "m4a": "/assets/sounds/pika.m4a" },
    "pikachu": { "wav": "/assets/sounds/pikachu.wav", "m4a": "/assets/sounds/pikachu.m4a" },
    "pipikachu": { "wav": "/assets/sounds/pipikachu.wav", "m4a": "/assets/sounds/pipikachu.m4a" },
    "chu": { "wav": "/assets/sounds/chu.wav", "m4a": "/assets/sounds/chu.m4a" },
    "powerhit": { "wav": "/assets/sounds/powerhit.wav", "m4a": "/assets/sounds/powerhit.m4a" },
    "bgm": { "mp3": "/assets/sounds/bgm.mp3" }
  }
}
